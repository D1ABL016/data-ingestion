# =============================================================================
# Environment template — copy to ".env" in this directory:
#   cp sample.env .env
# The app loads ".env" via data_ingestion/config.py (never commit real .env).
# =============================================================================

# --- PostgreSQL: choose ONE style ---

# Option A — Full connection URL (non-empty value wins; use this for odd URLs or SSL params).
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE_NAME

# Option B — Existing local Postgres (used when DATABASE_URL is unset, empty, or commented out).
# Update these to match your already-initialized database:
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# If you use Option B only, you can leave DATABASE_URL out of `.env` entirely.
# Default placeholders below match docker-compose.yml if you need a quick reference:
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=data_ingestion

# --- CSV upload storage ---
UPLOAD_DIR=/tmp/uploads

# --- Upload limits ---
MAX_UPLOAD_MB=200

# --- Application ---
DEBUG=false
